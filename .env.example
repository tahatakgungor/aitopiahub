# === UYGULAMA ===
APP_ENV=development
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
LOG_LEVEL=INFO

# === VERİTABANI ===
DATABASE_URL=postgresql+asyncpg://aitopiahub:aitopiahub@localhost:5432/aitopiahub

# === REDIS ===
REDIS_URL=redis://localhost:6379/0

# === GROQ API (LLM - Ücretsiz) ===
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# === OLLAMA (Local LLM Fallback) ===
OLLAMA_BASE_URL=http://localhost:11434

# === INSTAGRAM GRAPH API ===
# Meta Business hesabından alınır
INSTAGRAM_APP_ID=your_app_id
INSTAGRAM_APP_SECRET=your_app_secret
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id

# === REDDIT API (Ücretsiz) ===
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=aitopiahub/1.0

# === NEWS API (Ücretsiz tier - 100 req/gün) ===
NEWSAPI_KEY=your_newsapi_key

# === IMAGE STORAGE (MinIO local / Backblaze B2 prod) ===
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/images
PUBLIC_BASE_URL=http://localhost:8000
# STORAGE_S3_ENDPOINT=s3.us-east-005.backblazeb2.com
# STORAGE_S3_BUCKET=aitopiahub-images
# STORAGE_S3_KEY_ID=your_key_id
# STORAGE_S3_APP_KEY=your_app_key

# === ADMIN API ===
ADMIN_API_KEY=changeme-admin-api-key

# === MONETIZATION ===
# Varsayılanlar configs/*.yaml içinden gelir; burada env override gerekiyorsa kullanılabilir.
# MONETIZATION_ENABLED=true
