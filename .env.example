# === UYGULAMA ===
APP_ENV=development
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
LOG_LEVEL=INFO
ACCOUNT_HANDLE=aitopiahub_kids
KIDS_RUN_SLOTS=10:00,19:00
AUTOMATION_STRICT_FREE=true
ALLOW_PREMIUM_MODELS=false
MAX_COST_PER_VIDEO_USD=5.0
KIDS_RETRY_BUDGET=2
HYBRID_DAILY_MIX=1_fairy_1_demand
FAIRY_STYLE=modern_educational
FAIRY_LIBRARY_PATH=./configs/fairy_tales.yaml
SLOT1_MODE=fairy_tale
SLOT2_MODE=demand_driven

# === VERİTABANI ===
DATABASE_URL=postgresql+asyncpg://aitopiahub:aitopiahub@localhost:5432/aitopiahub

# === REDIS ===
REDIS_URL=redis://localhost:6379/0

# === GROQ API (LLM - Ücretsiz) ===
GROQ_API_KEY=your_groq_api_key

# === OLLAMA (Local LLM Fallback) ===
OLLAMA_BASE_URL=http://localhost:11434

# === TTS PROVIDERS (Quality First) ===
TTS_PROVIDER_PRIMARY=xtts_local
TTS_PROVIDER_SECONDARY=edge
TTS_PROVIDER_FALLBACK=piper
TTS_PROVIDER_PREMIUM=elevenlabs
XTTS_MODEL_PATH=/app/models/xtts/model.pth
XTTS_DEVICE=cpu
XTTS_BINARY=tts
PIPER_BINARY=piper
PIPER_MODEL_TR_PATH=/app/models/piper/tr_TR-dfki-medium.onnx
PIPER_MODEL_EN_PATH=/app/models/piper/en_US-lessac-medium.onnx
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_TR=
ELEVENLABS_VOICE_EN=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_COST_PER_1K_CHARS=0.30

# === VISUAL PROVIDERS ===
VISUAL_PROVIDER_PRIMARY=pexels
VISUAL_PROVIDER_SECONDARY=pixabay
VISUAL_PROVIDER_AI=pollinations
PEXELS_API_KEY=your_pexels_api_key
PIXABAY_API_KEY=your_pixabay_api_key

# === MUSIC + QUALITY GATE ===
MUSIC_POOL_MANIFEST=assets/music/kids_pool/music_manifest.json
QUALITY_GATE_STRICT=true
QUALITY_MIN_AUDIO=0.60
QUALITY_MIN_VISUAL=0.50
QUALITY_MIN_MUSIC=0.60
QUALITY_MIN_TECHNICAL=0.70

# === INSTAGRAM GRAPH API ===
# Meta Business hesabından alınır
INSTAGRAM_APP_ID=your_app_id
INSTAGRAM_APP_SECRET=your_app_secret
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id

# === REDDIT API (Ücretsiz) ===
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=aitopiahub/1.0

# === NEWS API (Ücretsiz tier - 100 req/gün) ===
NEWSAPI_KEY=your_newsapi_key

# === IMAGE STORAGE (MinIO local / Backblaze B2 prod) ===
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/images
PUBLIC_BASE_URL=http://localhost:8000
# STORAGE_S3_ENDPOINT=s3.us-east-005.backblazeb2.com
# STORAGE_S3_BUCKET=aitopiahub-images
# STORAGE_S3_KEY_ID=your_key_id
# STORAGE_S3_APP_KEY=your_app_key

# === ADMIN API ===
ADMIN_API_KEY=changeme-admin-api-key

# === MONETIZATION ===
# Varsayılanlar configs/*.yaml içinden gelir; burada env override gerekiyorsa kullanılabilir.
# MONETIZATION_ENABLED=true

# === PIPELINE FLAGS ===
ENABLE_SHORTS_PIPELINE=false
